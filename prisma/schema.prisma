generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  WORKER
}

enum JobStatus {
  NEW
  SCHEDULED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  PAYNOW
  CARD
  MANUAL_ADJUSTMENT
  OTHER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

model Company {
  id                   String                 @id @default(cuid())
  name                 String
  legalName            String?
  tradingName          String?
  registrationNumber   String?
  taxNumber            String?
  address              String?
  phone                String?
  email                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  users                User[]
  customers            Customer[]
  workers              WorkerProfile[]
  services             Service[]
  jobs                 Job[]
  scheduleItems        ScheduleItem[]
  quotes               Quote[]
  invoices             Invoice[]
  quoteLineItems       QuoteLineItem[]
  invoiceLineItems     InvoiceLineItem[]
  payments             Payment[]
  receipts             Receipt[]
  invoiceCounter       CompanyInvoiceCounter?
  workerLocations      WorkerLocation[]
  jobPhotos            JobPhoto[]
  auditLogs            AuditLog[]
  quoteStatusHistory   QuoteStatusHistory[]
  invoiceStatusHistory InvoiceStatusHistory[]
  branding             CompanyBranding?
}

model CompanyBranding {
  id             String   @id @default(cuid())
  companyId      String   @unique
  brandName      String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  supportEmail   String?
  supportPhone   String?
  websiteUrl     String?
  invoiceFooter  String?
  invoiceTerms   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model User {
  id                   String                 @id @default(cuid())
  companyId            String
  email                String                 @unique
  name                 String
  passwordHash         String
  role                 Role                   @default(WORKER)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker               WorkerProfile?
  auditLogs            AuditLog[]
  quoteStatusChanges   QuoteStatusHistory[]
  invoiceStatusChanges InvoiceStatusHistory[]
  paymentsCreated      Payment[]

  @@index([companyId])
}

model Customer {
  id        String    @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs      Job[]
  quotes    Quote[]
  invoices  Invoice[]

  @@index([companyId])
}

model WorkerProfile {
  id              String           @id @default(cuid())
  companyId       String
  userId          String           @unique
  title           String?
  phone           String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs            Job[]
  scheduleItems   ScheduleItem[]
  workerLocations WorkerLocation[]

  @@index([companyId])
}

model Service {
  id               String            @id @default(cuid())
  companyId        String
  name             String
  description      String?
  price            Decimal           @default(0) @db.Decimal(12, 2)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs             Job[]
  quotes           Quote[]
  invoices         Invoice[]
  quoteLineItems   QuoteLineItem[]
  invoiceLineItems InvoiceLineItem[]

  @@index([companyId])
}

model Job {
  id                   String         @id @default(cuid())
  companyId            String
  customerId           String
  serviceId            String?
  workerId             String?
  title                String
  description          String?
  status               JobStatus      @default(NEW)
  scheduledStart       DateTime?
  scheduledEnd         DateTime?
  completedAt          DateTime?
  completionNotes      String?
  customerSignatureUrl String?
  total                Decimal        @default(0) @db.Decimal(12, 2)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  company              Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer             Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service              Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  worker               WorkerProfile? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  scheduleItems        ScheduleItem[]
  quotes               Quote[]
  invoices             Invoice[]
  photos               JobPhoto[]

  @@index([companyId])
  @@index([companyId, customerId])
}

model ScheduleItem {
  id        String         @id @default(cuid())
  companyId String
  jobId     String
  workerId  String?
  startsAt  DateTime
  endsAt    DateTime?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job       Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    WorkerProfile? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Quote {
  id            String               @id @default(cuid())
  companyId     String
  customerId    String
  serviceId     String?
  jobId         String?
  title         String
  description   String?
  status        QuoteStatus          @default(DRAFT)
  amount        Decimal              @default(0) @db.Decimal(12, 2)
  subtotal      Decimal              @default(0) @db.Decimal(12, 2)
  discountTotal Decimal              @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal              @default(0) @db.Decimal(12, 2)
  total         Decimal              @default(0) @db.Decimal(12, 2)
  validUntil    DateTime?
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  expiredAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service       Service?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  job           Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoices      Invoice[]
  lineItems     QuoteLineItem[]
  statusHistory QuoteStatusHistory[]

  @@index([companyId])
}

model QuoteLineItem {
  id             String   @id @default(cuid())
  companyId      String
  quoteId        String
  serviceId      String?
  description    String
  quantity       Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([companyId, quoteId])
}

model QuoteStatusHistory {
  id          String       @id @default(cuid())
  companyId   String
  quoteId     String
  fromStatus  QuoteStatus?
  toStatus    QuoteStatus
  changedById String?
  note        String?
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quote       Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  changedBy   User?        @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([companyId, quoteId])
}

model CompanyInvoiceCounter {
  id         String   @id @default(cuid())
  companyId  String   @unique
  prefix     String   @default("INV")
  nextNumber Int      @default(1)
  padding    Int      @default(4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String                 @id @default(cuid())
  companyId     String
  customerId    String
  serviceId     String?
  jobId         String?
  number        String
  status        InvoiceStatus          @default(DRAFT)
  amount        Decimal                @default(0) @db.Decimal(12, 2)
  subtotal      Decimal                @default(0) @db.Decimal(12, 2)
  discountTotal Decimal                @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal                @default(0) @db.Decimal(12, 2)
  total         Decimal                @default(0) @db.Decimal(12, 2)
  balanceDue    Decimal                @default(0) @db.Decimal(12, 2)
  dueDate       DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  voidedAt      DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service       Service?               @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  job           Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?                 @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  payments      Payment[]
  receipts      Receipt[]
  lineItems     InvoiceLineItem[]
  statusHistory InvoiceStatusHistory[]

  @@unique([companyId, number])
  @@index([companyId])
}

model InvoiceLineItem {
  id             String   @id @default(cuid())
  companyId      String
  invoiceId      String
  serviceId      String?
  description    String
  quantity       Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([companyId, invoiceId])
}

model InvoiceStatusHistory {
  id          String         @id @default(cuid())
  companyId   String
  invoiceId   String
  fromStatus  InvoiceStatus?
  toStatus    InvoiceStatus
  changedById String?
  note        String?
  createdAt   DateTime       @default(now())
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  changedBy   User?          @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([companyId, invoiceId])
}

model Payment {
  id          String        @id @default(cuid())
  companyId   String
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(OTHER)
  status      PaymentStatus @default(PENDING)
  reference   String?
  receivedAt  DateTime?
  confirmedAt DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  receipt     Receipt?

  @@index([companyId])
}

model Receipt {
  id            String   @id @default(cuid())
  companyId     String
  invoiceId     String
  paymentId     String   @unique
  receiptNumber String
  amount        Decimal  @db.Decimal(12, 2)
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([companyId, receiptNumber])
  @@index([companyId, invoiceId])
}

model WorkerLocation {
  id         String        @id @default(cuid())
  companyId  String
  workerId   String
  latitude   Float
  longitude  Float
  recordedAt DateTime      @default(now())
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker     WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([companyId, workerId, recordedAt])
}

model JobPhoto {
  id        String   @id @default(cuid())
  companyId String
  jobId     String
  url       String
  caption   String?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([companyId, jobId])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}
