generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  WORKER
}

enum JobStatus {
  NEW
  SCHEDULED
  DISPATCHED
  ARRIVED
  IN_PROGRESS
  PAUSED
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum JobActivityType {
  ASSIGNED
  ARRIVED
  STARTED
  PAUSED
  RESUMED
  COMPLETED
  ADMIN_NOTE
  STATUS_CHANGED
  PROOF_PHOTO_ADDED
  PROOF_PHOTO_REMOVED
  SIGNATURE_ADDED
  SIGNATURE_REMOVED
  COMPLETION_LOCATION_CAPTURED
}

enum ProofPhotoCategory {
  BEFORE
  AFTER
  GENERAL
  DAMAGE
  ISSUE
  EXTRA_WORK
  CUSTOMER_APPROVAL
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  PAYNOW
  CARD
  MANUAL_ADJUSTMENT
  OTHER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum TimeOffStatus {
  APPROVED
  PENDING
  REJECTED
}

enum ScheduleStatus {
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum ScheduleConflictStatus {
  CLEAR
  CONFLICT
  OVERRIDE
}

enum ScheduleConflictType {
  OVERLAP
  TIME_OFF
  OUTSIDE_AVAILABILITY
  OUTSIDE_WORKING_HOURS
  INVALID_TIME
  JOB_NOT_SCHEDULABLE
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BookingRequestStatus {
  NEW
  REVIEWED
  CONVERTED
  DECLINED
  CANCELLED
}

enum ClientAccountStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum IntegrationProvider {
  BREVO
  META_WHATSAPP_CLOUD
  CLICKATELL
  AFRICAS_TALKING
  CLOUDFLARE_R2
}

enum IntegrationChannel {
  EMAIL
  WHATSAPP
  SMS
  STORAGE
}

enum IntegrationStatus {
  DISCONNECTED
  CONFIGURED
  ACTIVE
  ERROR
  DISABLED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  CANCELLED
}

model Company {
  id                     String                     @id @default(cuid())
  name                   String
  legalName              String?
  tradingName            String?
  registrationNumber     String?
  taxNumber              String?
  address                String?
  phone                  String?
  email                  String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  users                  User[]
  customers              Customer[]
  workers                WorkerProfile[]
  workerRoles            WorkerRole[]
  services               Service[]
  jobs                   Job[]
  scheduleItems          ScheduleItem[]
  quotes                 Quote[]
  invoices               Invoice[]
  quoteLineItems         QuoteLineItem[]
  invoiceLineItems       InvoiceLineItem[]
  payments               Payment[]
  receipts               Receipt[]
  invoiceCounter         CompanyInvoiceCounter?
  workerLocations        WorkerLocation[]
  jobProofPhotos         JobProofPhoto[]
  jobCompletionLocations JobCompletionLocation[]
  jobSignatures          JobSignature[]
  auditLogs              AuditLog[]
  jobActivities          JobActivity[]
  quoteStatusHistory     QuoteStatusHistory[]
  invoiceStatusHistory   InvoiceStatusHistory[]
  branding               CompanyBranding?
  schedulingSettings     CompanySchedulingSettings?
  workerAvailabilities   WorkerAvailability[]
  roleAvailabilities     RoleAvailability[]
  workerTimeOff          WorkerTimeOff[]
  scheduleConflicts      ScheduleConflict[]
  recurringJobRules      RecurringJobRule[]
  bookingRequests        BookingRequest[]
  bookingRequestPhotos   BookingRequestPhoto[]
  clientAccounts         ClientAccount[]
  customerProperties     CustomerProperty[]
  notificationLogs       NotificationLog[]
  integrationConnections IntegrationConnection[]
  integrationSecrets     IntegrationSecret[]
  messageLogs            MessageLog[]
  storageObjects         StorageObject[]
  storageUsageMonthly    StorageUsageMonthly[]
  securitySettings       CompanySecuritySettings?
  subscription           CompanySubscription?
  saasBillingEvents      SaaSBillingEvent[]
}

model SaaSPlan {
  id            String                @id
  name          String
  description   String?
  price         Decimal               @default(0)
  currency      String                @default("USD")
  interval      String                @default("month")
  isActive      Boolean               @default(true)
  limits        Json?
  features      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  subscriptions CompanySubscription[]

  @@index([isActive])
}

model CompanySubscription {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  planId             String?
  status             String             @default("TRIALING")
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  provider           String?
  providerCustomerId String?
  providerSubId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan               SaaSPlan?          @relation(fields: [planId], references: [id], onDelete: SetNull)
  events             SaaSBillingEvent[]

  @@index([companyId, status])
  @@index([planId])
  @@index([provider, providerSubId])
}

model SaaSBillingEvent {
  id             String               @id @default(cuid())
  companyId      String
  subscriptionId String?
  provider       String?
  eventType      String
  status         String
  amount         Decimal?
  currency       String?
  providerRef    String?
  message        String?
  createdAt      DateTime             @default(now())
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription   CompanySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, eventType, providerRef])
}

model CompanyBranding {
  id             String   @id @default(cuid())
  companyId      String   @unique
  brandName      String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  supportEmail   String?
  supportPhone   String?
  websiteUrl     String?
  invoiceFooter  String?
  invoiceTerms   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model User {
  id                          String                  @id @default(cuid())
  companyId                   String
  email                       String                  @unique
  name                        String
  phone                       String?
  passwordHash                String
  role                        Role                    @default(WORKER)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  company                     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker                      WorkerProfile?
  auditLogs                   AuditLog[]
  quoteStatusChanges          QuoteStatusHistory[]
  invoiceStatusChanges        InvoiceStatusHistory[]
  paymentsCreated             Payment[]
  jobActivities               JobActivity[]
  proofPhotosUploaded         JobProofPhoto[]         @relation("JobProofPhotoUploadedBy")
  signaturesCaptured          JobSignature[]          @relation("JobSignatureCapturedBy")
  jobsCompleted               Job[]                   @relation("JobCompletedBy")
  completionLocationsCaptured JobCompletionLocation[]
  storageObjectsUploaded      StorageObject[]

  @@index([companyId])
}

model Customer {
  id                String             @id @default(cuid())
  companyId         String
  name              String
  email             String?
  phone             String?
  address           String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs              Job[]
  quotes            Quote[]
  invoices          Invoice[]
  recurringJobRules RecurringJobRule[]
  bookingRequests   BookingRequest[]
  clientAccounts    ClientAccount[]
  properties        CustomerProperty[]
  messageLogs       MessageLog[]
  storageObjects    StorageObject[]

  @@index([companyId])
}

model ClientAccount {
  id              String              @id @default(cuid())
  companyId       String
  customerId      String?
  name            String
  email           String
  phone           String?
  passwordHash    String
  status          ClientAccountStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bookingRequests BookingRequest[]
  properties      CustomerProperty[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, customerId])
}

model CustomerProperty {
  id              String         @id @default(cuid())
  companyId       String
  customerId      String
  clientAccountId String?
  label           String
  address         String
  city            String?
  notes           String?
  isDefault       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  clientAccount   ClientAccount? @relation(fields: [clientAccountId], references: [id], onDelete: SetNull)

  @@index([companyId, customerId])
  @@index([companyId, clientAccountId])
  @@index([companyId, customerId, isDefault])
}

model WorkerRole {
  id           String             @id @default(cuid())
  companyId    String
  name         String
  description  String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workers      WorkerProfile[]
  availability RoleAvailability[]

  @@unique([companyId, name])
  @@index([companyId])
}

model WorkerProfile {
  id              String               @id @default(cuid())
  companyId       String
  userId          String               @unique
  roleId          String?
  title           String?
  phone           String?
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            WorkerRole?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  jobs            Job[]
  jobActivities   JobActivity[]
  proofPhotos     JobProofPhoto[]
  scheduleItems   ScheduleItem[]
  workerLocations WorkerLocation[]
  availability    WorkerAvailability[]
  timeOff         WorkerTimeOff[]
  conflicts       ScheduleConflict[]
  recurringRules  RecurringJobRule[]

  @@index([companyId])
  @@index([companyId, roleId])
}

model Service {
  id                String             @id @default(cuid())
  companyId         String
  name              String
  description       String?
  price             Decimal            @default(0) @db.Decimal(12, 2)
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs              Job[]
  quotes            Quote[]
  invoices          Invoice[]
  quoteLineItems    QuoteLineItem[]
  invoiceLineItems  InvoiceLineItem[]
  recurringJobRules RecurringJobRule[]
  bookingRequests   BookingRequest[]

  @@index([companyId])
}

model Job {
  id                   String                 @id @default(cuid())
  companyId            String
  customerId           String
  serviceId            String?
  workerId             String?
  title                String
  description          String?
  status               JobStatus              @default(NEW)
  scheduledStart       DateTime?
  scheduledEnd         DateTime?
  durationMinutes      Int?
  travelBufferMinutes  Int?
  rescheduledFromId    String?
  recurrenceRuleId     String?
  arrivedAt            DateTime?
  startedAt            DateTime?
  pausedAt             DateTime?
  resumedAt            DateTime?
  completedAt          DateTime?
  completedById        String?
  completionNotes      String?
  customerSignatureUrl String?
  requiresProofPhotos  Boolean                @default(false)
  minimumProofPhotos   Int                    @default(0)
  requiresBeforePhotos Boolean                @default(false)
  requiresAfterPhotos  Boolean                @default(false)
  requiresSignature    Boolean                @default(false)
  requiresLocation     Boolean                @default(false)
  proofCompletedAt     DateTime?
  signatureCompletedAt DateTime?
  total                Decimal                @default(0) @db.Decimal(12, 2)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer             Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service              Service?               @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  worker               WorkerProfile?         @relation(fields: [workerId], references: [id], onDelete: SetNull)
  completedBy          User?                  @relation("JobCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  scheduleItems        ScheduleItem[]
  quotes               Quote[]
  invoices             Invoice[]
  proofPhotos          JobProofPhoto[]
  completionLocation   JobCompletionLocation?
  signature            JobSignature?
  scheduleConflicts    ScheduleConflict[]
  activities           JobActivity[]
  bookingRequest       BookingRequest?
  messageLogs          MessageLog[]
  storageObjects       StorageObject[]

  @@index([companyId])
  @@index([companyId, customerId])
}

model JobActivity {
  id        String          @id @default(cuid())
  companyId String
  jobId     String
  workerId  String?
  userId    String?
  type      JobActivityType
  note      String?
  metadata  Json?
  createdAt DateTime        @default(now())
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job       Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    WorkerProfile?  @relation(fields: [workerId], references: [id], onDelete: SetNull)
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, jobId, createdAt])
  @@index([companyId, workerId, createdAt])
}

model ScheduleItem {
  id                  String                 @id @default(cuid())
  companyId           String
  jobId               String
  workerId            String?
  startsAt            DateTime
  endsAt              DateTime?
  status              ScheduleStatus         @default(SCHEDULED)
  conflictStatus      ScheduleConflictStatus @default(CLEAR)
  travelBufferMinutes Int                    @default(0)
  notes               String?
  createdById         String?
  updatedById         String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  company             Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job                 Job                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker              WorkerProfile?         @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, workerId, startsAt])
  @@index([companyId, jobId])
}

model Quote {
  id              String               @id @default(cuid())
  companyId       String
  customerId      String
  serviceId       String?
  jobId           String?
  title           String
  description     String?
  status          QuoteStatus          @default(DRAFT)
  amount          Decimal              @default(0) @db.Decimal(12, 2)
  subtotal        Decimal              @default(0) @db.Decimal(12, 2)
  discountTotal   Decimal              @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal              @default(0) @db.Decimal(12, 2)
  total           Decimal              @default(0) @db.Decimal(12, 2)
  validUntil      DateTime?
  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  expiredAt       DateTime?
  deletedAt       DateTime?
  deleteExpiresAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service         Service?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  job             Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoices        Invoice[]
  lineItems       QuoteLineItem[]
  statusHistory   QuoteStatusHistory[]

  @@index([companyId])
  @@index([companyId, deletedAt])
}

model QuoteLineItem {
  id             String   @id @default(cuid())
  companyId      String
  quoteId        String
  serviceId      String?
  description    String
  quantity       Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([companyId, quoteId])
}

model QuoteStatusHistory {
  id          String       @id @default(cuid())
  companyId   String
  quoteId     String
  fromStatus  QuoteStatus?
  toStatus    QuoteStatus
  changedById String?
  note        String?
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quote       Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  changedBy   User?        @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([companyId, quoteId])
}

model CompanyInvoiceCounter {
  id         String   @id @default(cuid())
  companyId  String   @unique
  prefix     String   @default("INV")
  nextNumber Int      @default(1)
  padding    Int      @default(4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String                 @id @default(cuid())
  companyId     String
  customerId    String
  serviceId     String?
  jobId         String?
  number        String
  status        InvoiceStatus          @default(DRAFT)
  amount        Decimal                @default(0) @db.Decimal(12, 2)
  subtotal      Decimal                @default(0) @db.Decimal(12, 2)
  discountTotal Decimal                @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal                @default(0) @db.Decimal(12, 2)
  total         Decimal                @default(0) @db.Decimal(12, 2)
  balanceDue    Decimal                @default(0) @db.Decimal(12, 2)
  dueDate       DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  voidedAt      DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service       Service?               @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  job           Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?                 @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  payments      Payment[]
  receipts      Receipt[]
  lineItems     InvoiceLineItem[]
  statusHistory InvoiceStatusHistory[]
  messageLogs   MessageLog[]

  @@unique([companyId, number])
  @@index([companyId])
}

model InvoiceLineItem {
  id             String   @id @default(cuid())
  companyId      String
  invoiceId      String
  serviceId      String?
  description    String
  quantity       Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([companyId, invoiceId])
}

model InvoiceStatusHistory {
  id          String         @id @default(cuid())
  companyId   String
  invoiceId   String
  fromStatus  InvoiceStatus?
  toStatus    InvoiceStatus
  changedById String?
  note        String?
  createdAt   DateTime       @default(now())
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  changedBy   User?          @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([companyId, invoiceId])
}

model Payment {
  id          String        @id @default(cuid())
  companyId   String
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(OTHER)
  status      PaymentStatus @default(PENDING)
  reference   String?
  receivedAt  DateTime?
  confirmedAt DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  receipt     Receipt?

  @@index([companyId])
}

model Receipt {
  id            String   @id @default(cuid())
  companyId     String
  invoiceId     String
  paymentId     String   @unique
  receiptNumber String
  amount        Decimal  @db.Decimal(12, 2)
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([companyId, receiptNumber])
  @@index([companyId, invoiceId])
}

model WorkerLocation {
  id         String        @id @default(cuid())
  companyId  String
  workerId   String
  latitude   Float
  longitude  Float
  recordedAt DateTime      @default(now())
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker     WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([companyId, workerId, recordedAt])
}

model CompanySchedulingSettings {
  id                         String    @id @default(cuid())
  companyId                  String    @unique
  defaultJobDurationMinutes  Int       @default(60)
  defaultTravelBufferMinutes Int       @default(0)
  allowOverbooking           Boolean   @default(false)
  defaultJobStatus           JobStatus @default(NEW)
  requireCompletionNotes     Boolean   @default(true)
  requireProofPhotos         Boolean   @default(true)
  requireBeforePhotos        Boolean   @default(false)
  requireAfterPhotos         Boolean   @default(false)
  requireLocation            Boolean   @default(false)
  autoCreateScheduleOnAssign Boolean   @default(false)
  timezone                   String    @default("UTC")
  workingDayStart            String    @default("08:00")
  workingDayEnd              String    @default("17:00")
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  company                    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model WorkerAvailability {
  id        String        @id @default(cuid())
  companyId String
  workerId  String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String        @default("UTC")
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([companyId, workerId, dayOfWeek])
}

model RoleAvailability {
  id        String     @id @default(cuid())
  companyId String
  roleId    String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String     @default("UTC")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      WorkerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([companyId, roleId, dayOfWeek])
}

model WorkerTimeOff {
  id        String        @id @default(cuid())
  companyId String
  workerId  String
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  status    TimeOffStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([companyId, workerId, startsAt])
}

model ScheduleConflict {
  id               String               @id @default(cuid())
  companyId        String
  jobId            String
  workerId         String
  conflictingJobId String?
  conflictType     ScheduleConflictType
  message          String
  resolved         Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job              Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker           WorkerProfile        @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([companyId, jobId])
  @@index([companyId, workerId])
}

model RecurringJobRule {
  id              String             @id @default(cuid())
  companyId       String
  customerId      String
  serviceId       String?
  workerId        String?
  title           String
  description     String?
  frequency       RecurringFrequency
  interval        Int                @default(1)
  startDate       DateTime
  endDate         DateTime?
  preferredTime   String?
  durationMinutes Int
  active          Boolean            @default(true)
  nextRunAt       DateTime
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service         Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  worker          WorkerProfile?     @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([companyId, nextRunAt])
}

model BookingRequest {
  id                    String                @id @default(cuid())
  companyId             String
  customerId            String?
  clientAccountId       String?
  serviceId             String?
  status                BookingRequestStatus  @default(NEW)
  publicReference       String?               @unique
  customerName          String
  customerEmail         String?
  customerPhone         String?
  address               String?
  city                  String?
  propertyType          String?
  accessNotes           String?
  serviceName           String?
  preferredDate         DateTime?
  preferredTimeWindow   String?
  notes                 String?
  source                String?
  customerFacingMessage String?
  convertedJobId        String?               @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer              Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  clientAccount         ClientAccount?        @relation(fields: [clientAccountId], references: [id], onDelete: SetNull)
  service               Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  convertedJob          Job?                  @relation(fields: [convertedJobId], references: [id], onDelete: SetNull)
  photos                BookingRequestPhoto[]
  messageLogs           MessageLog[]
  storageObjects        StorageObject[]

  @@index([companyId, status, createdAt])
  @@index([companyId, publicReference])
  @@index([companyId, customerId])
  @@index([companyId, clientAccountId])
  @@index([companyId, serviceId])
}

model BookingRequestPhoto {
  id               String         @id @default(cuid())
  companyId        String
  bookingRequestId String
  url              String
  filename         String
  originalName     String?
  mimeType         String
  sizeBytes        Int
  caption          String?
  createdAt        DateTime       @default(now())
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookingRequest   BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)

  @@index([companyId, bookingRequestId])
}

model JobProofPhoto {
  id           String             @id @default(cuid())
  companyId    String
  jobId        String
  workerId     String?
  uploadedById String?
  url          String
  filename     String
  mimeType     String
  sizeBytes    Int
  category     ProofPhotoCategory @default(GENERAL)
  caption      String?
  createdAt    DateTime           @default(now())
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job          Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker       WorkerProfile?     @relation(fields: [workerId], references: [id], onDelete: SetNull)
  uploadedBy   User?              @relation("JobProofPhotoUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId, jobId])
  @@index([companyId, workerId])
  @@index([companyId, uploadedById])
}

model JobCompletionLocation {
  id           String   @id @default(cuid())
  companyId    String
  jobId        String   @unique
  capturedById String?
  latitude     Float
  longitude    Float
  accuracy     Float?
  source       String?
  capturedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  capturedBy   User?    @relation(fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([companyId, jobId])
  @@index([companyId, capturedById])
}

model JobSignature {
  id           String   @id @default(cuid())
  companyId    String
  jobId        String   @unique
  capturedById String?
  signerName   String?
  signatureUrl String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  capturedBy   User?    @relation("JobSignatureCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([companyId, jobId])
  @@index([companyId, capturedById])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model NotificationLog {
  id          String       @id @default(cuid())
  companyId   String
  eventType   String
  channel     String
  recipient   String
  subject     String?
  status      String
  error       String?
  relatedType String?
  relatedId   String?
  createdAt   DateTime     @default(now())
  sentAt      DateTime?
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messageLogs MessageLog[]

  @@index([companyId, createdAt])
  @@index([companyId, eventType, relatedType, relatedId])
  @@index([companyId, recipient])
}

model IntegrationConnection {
  id             String              @id @default(cuid())
  companyId      String
  provider       IntegrationProvider
  channel        IntegrationChannel
  displayName    String?
  status         IntegrationStatus   @default(DISCONNECTED)
  config         Json?
  lastTestedAt   DateTime?
  lastTestStatus String?
  lastTestError  String?
  lastUsedAt     DateTime?
  createdById    String?
  updatedById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  secrets        IntegrationSecret[]
  messageLogs    MessageLog[]
  storageObjects StorageObject[]

  @@unique([companyId, provider])
  @@index([companyId])
  @@index([provider])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model IntegrationSecret {
  id                      String                @id @default(cuid())
  companyId               String
  integrationConnectionId String
  keyName                 String
  encryptedValue          String
  iv                      String
  authTag                 String
  keyVersion              String
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  company                 Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integrationConnection   IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)

  @@unique([integrationConnectionId, keyName])
  @@index([companyId])
  @@index([integrationConnectionId])
}

model MessageLog {
  id                      String                 @id @default(cuid())
  companyId               String
  integrationConnectionId String?
  provider                IntegrationProvider
  channel                 IntegrationChannel
  direction               MessageDirection       @default(OUTBOUND)
  status                  MessageStatus          @default(QUEUED)
  bookingId               String?
  jobId                   String?
  customerId              String?
  invoiceId               String?
  notificationLogId       String?
  recipientMasked         String?
  recipientHash           String?
  senderMasked            String?
  providerMessageId       String?
  providerStatus          String?
  errorCode               String?
  errorMessageSanitized   String?
  templateName            String?
  metadata                Json?
  queuedAt                DateTime?
  sentAt                  DateTime?
  deliveredAt             DateTime?
  failedAt                DateTime?
  readAt                  DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  company                 Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integrationConnection   IntegrationConnection? @relation(fields: [integrationConnectionId], references: [id], onDelete: SetNull)
  booking                 BookingRequest?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  job                     Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  customer                Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice                 Invoice?               @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  notificationLog         NotificationLog?       @relation(fields: [notificationLogId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([provider])
  @@index([channel])
  @@index([status])
  @@index([bookingId])
  @@index([jobId])
  @@index([customerId])
  @@index([createdAt])
}

model StorageObject {
  id                      String                 @id @default(cuid())
  companyId               String
  integrationConnectionId String?
  provider                IntegrationProvider    @default(CLOUDFLARE_R2)
  bucket                  String
  objectKey               String
  safeUrl                 String?
  fileName                String?
  mimeType                String?
  sizeBytes               BigInt
  checksum                String?
  bookingId               String?
  jobId                   String?
  customerId              String?
  uploadedById            String?
  createdAt               DateTime               @default(now())
  deletedAt               DateTime?
  company                 Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integrationConnection   IntegrationConnection? @relation(fields: [integrationConnectionId], references: [id], onDelete: SetNull)
  booking                 BookingRequest?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  job                     Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  customer                Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  uploadedBy              User?                  @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([provider])
  @@index([bucket])
  @@index([jobId])
  @@index([bookingId])
  @@index([customerId])
  @@index([createdAt])
}

model StorageUsageMonthly {
  id          String              @id @default(cuid())
  companyId   String
  provider    IntegrationProvider @default(CLOUDFLARE_R2)
  year        Int
  month       Int
  totalBytes  BigInt              @default(0)
  objectCount Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider, year, month])
  @@index([companyId])
  @@index([provider])
}

model CompanySecuritySettings {
  id                 String   @id @default(cuid())
  companyId          String   @unique
  sessionLengthHours Int      @default(8)
  passwordMinimum    Int      @default(8)
  twoFactorEnabled   Boolean  @default(false)
  twoFactorRequired  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
