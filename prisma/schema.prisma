model Company {
  id                     String                     @id @default(cuid())
  name                   String
  legalName              String?
  tradingName            String?
  registrationNumber     String?
  taxNumber              String?
  address                String?
  phone                  String?
  email                  String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  allowNegativeStock     Boolean                    @default(false)
  purchaseRequestApprovalThreshold Decimal          @default(1000) @db.Decimal(12, 2)
  purchaseOrderApprovalThreshold Decimal            @default(2500) @db.Decimal(12, 2)
  stockAdjustmentApprovalThreshold Decimal          @default(500) @db.Decimal(12, 2)
  users                  User[]
  customers              Customer[]
  workers                WorkerProfile[]
  workerRoles            WorkerRole[]
  services               Service[]
  jobs                   Job[]
  scheduleItems          ScheduleItem[]
  quotes                 Quote[]
  invoices               Invoice[]
  quoteLineItems         QuoteLineItem[]
  invoiceLineItems       InvoiceLineItem[]
  payments               Payment[]
  receipts               Receipt[]
  paymentProviderConnections PaymentProviderConnection[]
  paymentProviderSecrets PaymentProviderSecret[]
  paymentLinks           PaymentLink[]
  paymentProviderEvents  PaymentProviderEvent[]
  paymentReconciliationItems PaymentReconciliationItem[]
  paymentRefunds         PaymentRefund[]
  creditNotes            CreditNote[]
  collectionReminderRules CollectionReminderRule[]
  collectionReminderLogs CollectionReminderLog[]
  invoiceCounter         CompanyInvoiceCounter?
  workerLocations        WorkerLocation[]
  jobProofPhotos         JobProofPhoto[]
  jobCompletionLocations JobCompletionLocation[]
  jobSignatures          JobSignature[]
  auditLogs              AuditLog[]
  jobActivities          JobActivity[]
  quoteStatusHistory     QuoteStatusHistory[]
  invoiceStatusHistory   InvoiceStatusHistory[]
  branding               CompanyBranding?
  schedulingSettings     CompanySchedulingSettings?
  workerAvailabilities   WorkerAvailability[]
  roleAvailabilities     RoleAvailability[]
  workerTimeOff          WorkerTimeOff[]
  scheduleConflicts      ScheduleConflict[]
  recurringJobRules      RecurringJobRule[]
  bookingRequests        BookingRequest[]
  bookingRequestPhotos   BookingRequestPhoto[]
  clientAccounts         ClientAccount[]
  customerProperties     CustomerProperty[]
  notificationLogs       NotificationLog[]
  integrationConnections IntegrationConnection[]
  integrationSecrets     IntegrationSecret[]
  messageLogs            MessageLog[]
  storageObjects         StorageObject[]
  storageUsageMonthly    StorageUsageMonthly[]
  securitySettings       CompanySecuritySettings?
  userSessions           UserSession[]
  identityProviderConfigs IdentityProviderConfig[]
  securityEvents         SecurityEvent[]
  subscription           CompanySubscription?
  saasBillingEvents      SaaSBillingEvent[]
  assets                 Asset[]
  jobAssets              JobAsset[]
  serviceContracts       ServiceContract[]
  serviceContractAssets  ServiceContractAsset[]
  contractServiceLines   ContractServiceLine[]
  suppliers              Supplier[]
  stockLocations         StockLocation[]
  inventoryItems         InventoryItem[]
  inventoryStocks        InventoryStock[]
  stockMovements         StockMovement[]
  jobPartUsages          JobPartUsage[]
  purchaseRequests       PurchaseRequest[]
  purchaseRequestLines   PurchaseRequestLine[]
  purchaseOrders         PurchaseOrder[]
  purchaseOrderLines     PurchaseOrderLine[]
  financeSettings        CompanyFinanceSettings?
  financeIntegrations    FinanceIntegration[]
  financeIntegrationSecrets FinanceIntegrationSecret[]
  financeMappings        FinanceMapping[]
  financeSyncLogs        FinanceSyncLog[]
  financeWebhookEvents   FinanceWebhookEvent[]
  externalRecordLinks    ExternalRecordLink[]
  financeExportLogs      FinanceExportLog[]
  workerDevices          WorkerDevice[]
  offlineActionQueues    OfflineActionQueue[]
  jobChecklistTemplates JobChecklistTemplate[]
  jobChecklistItems     JobChecklistItem[]
  jobChecklistAnswers   JobChecklistAnswer[]
  branches               Branch[]
  approvalPolicies       ApprovalPolicy[]
  approvalRequests       ApprovalRequest[]
  permissionRoleTemplates PermissionRoleTemplate[]
  userPermissionOverrides UserPermissionOverride[]
  userBranchAccesses      UserBranchAccess[]
  implementationSettings  CompanyImplementationSettings?
  onboardingPackages      CompanyOnboardingPackage[]
  dataImportJobs          DataImportJob[]
  dataImportRowErrors     DataImportRowError[]
}

model SaaSPlan {
  id            String                @id
  name          String
  description   String?
  price         Decimal               @default(0)
  currency      String                @default("USD")
  interval      String                @default("month")
  isActive      Boolean               @default(true)
  limits        Json?
  features      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  subscriptions CompanySubscription[]

  @@index([isActive])
}

model CompanySubscription {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  planId             String?
  status             String             @default("TRIALING")
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  provider           String?
  providerCustomerId String?
  providerSubId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan               SaaSPlan?          @relation(fields: [planId], references: [id], onDelete: SetNull)
  events             SaaSBillingEvent[]

  @@index([companyId, status])
  @@index([planId])
  @@index([provider, providerSubId])
}

model SaaSBillingEvent {
  id             String               @id @default(cuid())
  companyId      String
  subscriptionId String?
  provider       String?
  eventType      String
  status         String
  amount         Decimal?
  currency       String?
  providerRef    String?
  message        String?
  createdAt      DateTime             @default(now())
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription   CompanySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, eventType, providerRef])
}

model CompanyBranding {
  id             String   @id @default(cuid())
  companyId      String   @unique
  brandName      String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  supportEmail   String?
  supportPhone   String?
  websiteUrl     String?
  invoiceFooter  String?
  invoiceTerms   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model User {
  id                          String                  @id @default(cuid())
  companyId                   String
  email                       String                  @unique
  name                        String
  phone                       String?
  passwordHash                String
  role                        Role                    @default(WORKER)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  company                     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker                      WorkerProfile?
  auditLogs                   AuditLog[]
  quoteStatusChanges          QuoteStatusHistory[]
  invoiceStatusChanges        InvoiceStatusHistory[]
  paymentsCreated             Payment[]
  jobActivities               JobActivity[]
  proofPhotosUploaded         JobProofPhoto[]         @relation("JobProofPhotoUploadedBy")
  signaturesCaptured          JobSignature[]          @relation("JobSignatureCapturedBy")
  jobsCompleted               Job[]                   @relation("JobCompletedBy")
  completionLocationsCaptured JobCompletionLocation[]
  storageObjectsUploaded      StorageObject[]
  stockMovementsCreated       StockMovement[]         @relation("StockMovementCreatedBy")
  purchaseRequestsCreated     PurchaseRequest[]       @relation("PurchaseRequestRequestedBy")
  purchaseRequestsApproved    PurchaseRequest[]       @relation("PurchaseRequestApprovedBy")
  purchaseRequestsRejected    PurchaseRequest[]       @relation("PurchaseRequestRejectedBy")
  purchaseOrdersApproved      PurchaseOrder[]         @relation("PurchaseOrderApprovedBy")
  financeExportLogsCreated    FinanceExportLog[]      @relation("FinanceExportLogCreatedBy")
  financeSyncLogsCreated      FinanceSyncLog[]        @relation("FinanceSyncLogCreatedBy")
  workerDevices               WorkerDevice[]
  offlineActionQueues         OfflineActionQueue[]
  workerDevicesRevoked        WorkerDevice[]          @relation("WorkerDeviceRevokedBy")
  checklistAnswersCaptured    JobChecklistAnswer[]    @relation("ChecklistAnswerCapturedBy")
  approvalRequestsMade        ApprovalRequest[]       @relation("ApprovalRequestRequestedBy")
  approvalRequestsDecided     ApprovalRequest[]       @relation("ApprovalRequestDecidedBy")
  permissionOverrides         UserPermissionOverride[]
  branchAccesses              UserBranchAccess[]
  twoFactorEnabled            Boolean                 @default(false)
  twoFactorSecretHash         String?
  twoFactorRecoveryCodes      Json?
  failedLoginCount            Int                     @default(0)
  lockedUntil                 DateTime?
  disabledAt                  DateTime?
  mustResetPassword           Boolean                 @default(false)
  passwordChangedAt           DateTime?
  sessions                    UserSession[]
  securityEvents              SecurityEvent[]

  @@index([companyId])
  @@index([companyId, role])
  @@index([companyId, lockedUntil])
}

model Branch {
  id               String            @id @default(cuid())
  companyId        String
  name             String
  code             String?
  country          String?
  city             String?
  address          String?
  timezone         String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customers        Customer[]
  properties       CustomerProperty[]
  workers          WorkerProfile[]
  jobs             Job[]
  quotes           Quote[]
  invoices         Invoice[]
  payments         Payment[]
  receipts         Receipt[]
  assets           Asset[]
  serviceContracts ServiceContract[]
  stockLocations   StockLocation[]
  purchaseRequests PurchaseRequest[]
  purchaseRequestLines PurchaseRequestLine[]
  purchaseOrders   PurchaseOrder[]
  approvalPolicies ApprovalPolicy[]
  approvalRequests ApprovalRequest[]
  userBranchAccesses UserBranchAccess[]

  @@unique([companyId, code])
  @@index([companyId, active])
}

model ApprovalPolicy {
  id                   String            @id @default(cuid())
  companyId            String
  branchId             String?
  name                 String
  eventType            ApprovalEventType
  thresholdAmount      Decimal?          @db.Decimal(12, 2)
  requiredApproverRole Role              @default(OWNER)
  allowSelfApproval    Boolean           @default(false)
  reasonRequired       Boolean           @default(false)
  expiresAfterHours    Int?
  active               Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  company              Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch               Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requests             ApprovalRequest[]

  @@index([companyId, eventType, active])
  @@index([companyId, branchId, eventType, active])
}

model ApprovalRequest {
  id              String            @id @default(cuid())
  companyId       String
  branchId        String?
  policyId        String?
  requestedById   String
  approvedById    String?
  entityType      String
  entityId        String
  eventType       ApprovalEventType
  actionKey       String?
  actionPayload   Json?
  amount          Decimal?          @db.Decimal(12, 2)
  thresholdAmount Decimal?          @db.Decimal(12, 2)
  status          ApprovalStatus    @default(PENDING)
  reason          String?
  decisionNote    String?
  expiresAt       DateTime?
  executedAt      DateTime?
  executionResult Json?
  createdAt       DateTime          @default(now())
  decidedAt       DateTime?
  updatedAt       DateTime          @updatedAt
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  policy          ApprovalPolicy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)
  requestedBy     User              @relation("ApprovalRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedBy      User?             @relation("ApprovalRequestDecidedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt])
  @@index([companyId, branchId, status, createdAt])
  @@index([companyId, entityType, entityId])
  @@index([companyId, eventType, status])
  @@index([companyId, actionKey, status])
}


model PermissionRoleTemplate {
  id          String   @id @default(cuid())
  companyId   String?
  role        Role
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, role])
  @@index([companyId])
}

model UserPermissionOverride {
  id            String   @id @default(cuid())
  companyId     String
  userId        String
  permissionKey String
  allowed       Boolean  @default(true)
  branchId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, permissionKey, branchId])
  @@index([companyId, permissionKey])
  @@index([companyId, userId])
}

model UserBranchAccess {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  branchId    String
  permissions Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, branchId])
  @@index([companyId, branchId])
  @@index([companyId, userId, active])
}

model Customer {
  id                String             @id @default(cuid())
  companyId         String
  branchId          String?
  name              String
  email             String?
  phone             String?
  address           String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  jobs              Job[]
  quotes            Quote[]
  invoices          Invoice[]
  recurringJobRules RecurringJobRule[]
  bookingRequests   BookingRequest[]
  clientAccounts    ClientAccount[]
  properties        CustomerProperty[]
  messageLogs       MessageLog[]
  storageObjects    StorageObject[]
  assets            Asset[]
  serviceContracts  ServiceContract[]

  @@index([companyId])
  @@index([companyId, branchId])
}

model ClientAccount {
  id              String              @id @default(cuid())
  companyId       String
  customerId      String?
  name            String
  email           String
  phone           String?
  passwordHash    String
  status          ClientAccountStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bookingRequests BookingRequest[]
  properties      CustomerProperty[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, customerId])
}

model CustomerProperty {
  id               String            @id @default(cuid())
  companyId        String
  branchId         String?
  customerId       String
  clientAccountId  String?
  label            String
  address          String
  city             String?
  notes            String?
  isDefault        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  clientAccount    ClientAccount?    @relation(fields: [clientAccountId], references: [id], onDelete: SetNull)
  assets           Asset[]
  serviceContracts ServiceContract[]

  @@index([companyId, customerId])
  @@index([companyId, clientAccountId])
  @@index([companyId, customerId, isDefault])
  @@index([companyId, branchId])
}

model WorkerRole {
  id           String             @id @default(cuid())
  companyId    String
  name         String
  description  String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workers      WorkerProfile[]
  availability RoleAvailability[]

  @@unique([companyId, name])
  @@index([companyId])
}

model WorkerProfile {
  id              String               @id @default(cuid())
  companyId       String
  branchId        String?
  userId          String               @unique
  roleId          String?
  title           String?
  phone           String?
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            WorkerRole?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  jobs            Job[]
  jobActivities   JobActivity[]
  proofPhotos     JobProofPhoto[]
  scheduleItems   ScheduleItem[]
  workerLocations WorkerLocation[]
  availability    WorkerAvailability[]
  timeOff         WorkerTimeOff[]
  conflicts       ScheduleConflict[]
  recurringRules  RecurringJobRule[]
  stockLocations  StockLocation[]
  jobPartUsages   JobPartUsage[]
